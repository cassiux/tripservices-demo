{
  "name": "smartpoint-cloud",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Smartpoint Cloud (SPC) — professional travel agent desktop application built on TripServices.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:api": "openapi-typescript ./openapi/tripservices.yaml -o src/lib/api/types/tripservices.ts",
    "start": "node server.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.22.2",
    "i18next": "^26.3.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
