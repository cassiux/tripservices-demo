# .env.example — COMMIT THIS (placeholders only). Copy to .env.local and fill real
# values. .env.local is git-ignored and never committed.
# =============================================================================
# TripServices API (Travelport)
#   Token flow: POST {AUTH_URL} grant_type=client_credentials with all four credential
#   fields in the body (username + password + client_id + client_secret) -> Bearer token.
#   The portal username/password and the API client_id/secret are separate credential
#   pairs; all four are required. Pre-production hosts use *.pp.travelport.net.
#
#   Browser CORS: the app must not call Travelport cross-origin from the browser.
#   In dev, the URLs below are same-origin proxy paths fronted by the Vite dev
#   server (see vite.config.ts), which forwards them server-side to the real
#   upstreams in VITE_DEV_*_TARGET. For a production build, set BASE/AUTH_URL back
#   to the real endpoints (or your server-side proxy) — no code changes needed.
# =============================================================================

VITE_TRIPSERVICES_BASE_URL=/tp-api/
VITE_TRIPSERVICES_AUTH_URL=/tp-auth/oauth/token
VITE_DEV_API_TARGET=https://api.pp.travelport.net
VITE_DEV_AUTH_TARGET=https://auth.pp.travelport.net
VITE_TRIPSERVICES_CLIENT_ID=your-client-id-here
VITE_TRIPSERVICES_CLIENT_SECRET=your-client-secret-here
VITE_TRIPSERVICES_USERNAME=your-username-here
VITE_TRIPSERVICES_PASSWORD=your-password-here

# Per-request agency context (sent in API headers/payloads):
VITE_TRIPSERVICES_PCC=your-pcc
VITE_TRIPSERVICES_ACCESS_GROUP=your-access-group-guid
VITE_TRIPSERVICES_REGION=NORAM
VITE_DEFAULT_CURRENCY=USD

VITE_ENV=development

# =============================================================================
# Okta SSO — production auth per CLAUDE.md (PKCE; no client secret in browser)
# =============================================================================
VITE_OKTA_ISSUER=https://your-org.okta.com/oauth2/default
VITE_OKTA_CLIENT_ID=your-okta-client-id-here
VITE_OKTA_REDIRECT_URI=http://localhost:5173/login/callback
